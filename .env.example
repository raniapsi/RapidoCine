# Database Configuration (pour PostgreSQL local)
POSTGRES_USER=rapidocine_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=rapidocine_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Database URL pour SQLAlchemy
DATABASE_URL=postgresql://rapidocine_user:your_secure_password_here@localhost:5432/rapidocine_db

# JWT Configuration
SECRET_KEY=your_super_secret_key_change_this_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Origins (séparés par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
